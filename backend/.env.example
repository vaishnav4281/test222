# ==============================================
# 🔙 BACKEND CONFIGURATION
# ==============================================
# Copy this file to .env in the backend directory.

# Server Settings
PORT=3001
NODE_ENV=development

# Database Connection (Prisma/PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Redis Connection (Caching & Queues)
REDIS_URL="redis://localhost:6379"

# Security & Authentication
JWT_SECRET="supersecretkey123"
# Allowed origins for CORS. Comma-separated.
FRONTEND_URL="http://localhost:8080,http://localhost:5173"

# Email Service (Resend)
RESEND_API_KEY="re_123456789"

# --- External Intelligence APIs (REQUIRED) ---
# The backend services rely on these keys to perform scans.
# Without them, the backend cannot fetch data from external providers.

# VirusTotal
VITE_VIRUSTOTAL_API_KEY=your_vt_key

# IPQualityScore (Supports multiple keys for rotation)
VITE_IPQS_API_KEY=your_ipqs_key
VITE_IPQS_API_KEY_2=optional_backup_key

# AbuseIPDB
VITE_ABUSEIPDB_API_KEY=your_abuseipdb_key
