# ==============================================
# 🎨 FRONTEND CONFIGURATION
# ==============================================
# Copy this file to .env in the root directory.

# API Connection (REQUIRED)
# This is the only link the frontend needs to talk to the backend.
VITE_API_URL="http://localhost:3001"

# --- Optional: Dev Proxy Configuration ---
# These keys are NOT required for the app to work if the backend is running.
# They are only used by the Vite Dev Server (vite.config.ts) to proxy requests
# directly to external APIs as a fallback if the backend is down.

# VirusTotal (Optional - Supports multiple keys for rotation)
VITE_VIRUSTOTAL_API_KEY=your_vt_key
VITE_VIRUSTOTAL_API_KEY_2=optional_backup_key_2
VITE_VIRUSTOTAL_API_KEY_3=optional_backup_key_3
VITE_VIRUSTOTAL_API_KEY_4=optional_backup_key_4
VITE_VIRUSTOTAL_API_KEY_5=optional_backup_key_5

# IPQualityScore (Optional - Supports multiple keys for rotation)
VITE_IPQS_API_KEY=your_ipqs_key
VITE_IPQS_API_KEY_2=optional_backup_key_2
VITE_IPQS_API_KEY_3=optional_backup_key_3
VITE_IPQS_API_KEY_4=optional_backup_key_4
VITE_IPQS_API_KEY_5=optional_backup_key_5

# AbuseIPDB (Optional)
VITE_ABUSEIPDB_API_KEY=your_abuseipdb_key
